{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Finup API",
  "description": "Client-facing API documentation for Finup accounts, cards, users, and transactions.",
  "logo": {
    "light": "/logo/finup-blck.svg",
    "dark": "/logo/finup-wht.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#3B66FF",
    "light": "#6F8CFF",
    "dark": "#2C54DE"
  },
  "icons": {
    "library": "lucide"
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["curl", "javascript", "python"],
      "defaults": "required"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://app.finup.io"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Start",
            "pages": [
              "introduction",
              "quickstart",
              "guides/authentication",
              "guides/webhooks",
              "guides/pagination",
              "guides/errors"
            ]
          },
          {
            "group": "MCP",
            "pages": [
              "guides/mcp"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "reference/overview",
              "reference/users"
            ]
          },
          {
            "group": "Accounts",
            "openapi": "openapi.json",
            "pages": [
              "POST /accounts",
              "GET /account",
              "GET /bins"
            ]
          },
          {
            "group": "Transactions",
            "openapi": "openapi.json",
            "pages": [
              "POST /transactions",
              "POST /transactions/count",
              "POST /transactions/summary"
            ]
          },
          {
            "group": "Cards",
            "openapi": "openapi.json",
            "pages": [
              "POST /cards",
              "POST /cards/get",
              "GET /cards/{card_id}",
              "POST /card/{card_id}/deposit",
              "POST /card/{card_id}/withdraw",
              "PATCH /cards/freeze",
              "PATCH /cards/unfreeze",
              "PATCH /cards/close"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://finup.io"
    }
  }
}
